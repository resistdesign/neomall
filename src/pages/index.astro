---
import "../styles/site.css";

const siteUrl = "https://neomall.resist.design/";
const title = "Neo Mall | Free-To-Enter Daily Resort Town Square";
const description =
  "Neo Mall reframes the mall as a free-to-enter daily resort town square built around food, play, water, entertainment, work, comfort, and community.";
const ogImage = `${siteUrl}og-image.png`;

const navItems = [
  ["#vision", "Vision"],
  ["#moments", "Moments"],
  ["#map", "Map"],
  ["#rhythm", "Rhythm"],
];

const stack = [
  ["Play", "Water, arcade, bowling, skate, courts, and small moments of discovery."],
  ["Stay", "Grass, shade, bathrooms, WiFi, seating, and a reason to settle in."],
  ["Eat", "Food hall energy with cafes, small vendors, patio dining, and coffee."],
  ["Shop", "Useful, casual retail that benefits from people already choosing to linger."],
  ["Return", "Daily usefulness turns a special trip into a repeat habit."],
];

const moments = [
  {
    id: "arrival",
    title: "Arrival Moment",
    image: "/assets/scenes/hero.webp",
    text: "The front door should feel like a public plaza: visible activity, warm storefronts, seating, planting, and clear paths into the courtyard.",
  },
  {
    id: "promenade",
    title: "Covered Promenade",
    image: "/assets/scenes/promenade.webp",
    text: "Continuous cover lets people eat, work, meet, and wander without the weather deciding whether the day works.",
  },
  {
    id: "courtyard",
    title: "Grass Courtyard",
    image: "/assets/scenes/lawn.webp",
    text: "The center stays mostly green, controlled, and intentional: clean lawn panels, planted edges, shade, benches, picnic tables, and direct paths.",
  },
  {
    id: "water",
    title: "Wave Pool Feature",
    image: "/assets/scenes/hero.webp",
    text: "The water becomes a memorable draw while the broader space still reads as a mall courtyard, not only a water park.",
  },
  {
    id: "night",
    title: "Night Economy",
    image: "/assets/scenes/night.webp",
    text: "Warm lights, cafes, games, theater, bowling, lawn seating, and safe paths keep the complex alive past shopping hours.",
  },
  {
    id: "active",
    title: "Active Edge",
    image: "/assets/scenes/active-edge.webp",
    text: "Skate, courts, trails, and optional lodging broaden the audience without pulling focus from the central commons.",
  },
];

const planStops = [
  ["10:30", "Coffee and laptop under the roof"],
  ["12:00", "Lunch, picnic tables, kids on the grass"],
  ["2:00", "Wave pool or water park"],
  ["4:30", "Skate park, courts, trail loop"],
  ["6:00", "Food hall, arcade, bowling"],
  ["8:00", "Movie, dessert, walk out safely"],
];

const zones = [
  {
    id: "water",
    label: "Water park",
    title: "Water Park Edge",
    text: "The left edge stays open to water so the attraction feels connected to the public space instead of bolted on.",
    style: "--x: 5%; --y: 16%; --w: 18%; --h: 68%;",
  },
  {
    id: "food-north",
    label: "Food + cafes",
    title: "Food And Cafe Spine",
    text: "Food and cafe frontage frame both sides of the commons, turning ordinary meals into the main social engine.",
    style: "--x: 26%; --y: 6%; --w: 58%; --h: 14%;",
  },
  {
    id: "roof",
    label: "Covered seating",
    title: "Covered Promenade",
    text: "A roofed promenade makes the place usable in heat, rain, and cooler months while keeping the courtyard visible.",
    style: "--x: 27%; --y: 22%; --w: 54%; --h: 15%;",
  },
  {
    id: "pool",
    label: "Wave pool",
    title: "Wave Pool Feature",
    text: "The pool is the visual anchor: social, visible, and memorable without consuming the entire identity.",
    style: "--x: 29%; --y: 39%; --w: 28%; --h: 23%;",
  },
  {
    id: "commons",
    label: "Outdoor commons",
    title: "Outdoor Seating And Play",
    text: "Open lawn and seating form the free daily commons where people can arrive without buying a ticket.",
    style: "--x: 58%; --y: 39%; --w: 22%; --h: 23%;",
  },
  {
    id: "entertainment",
    label: "Entertainment",
    title: "Entertainment Edge",
    text: "Arcade, bowling, theater, and service uses concentrate on the active side so nights have a clear destination.",
    style: "--x: 86%; --y: 10%; --w: 9%; --h: 70%;",
  },
  {
    id: "food-south",
    label: "Food + cafes",
    title: "South Food Spine",
    text: "A second food edge creates loops, choices, and reasons to move through the whole site.",
    style: "--x: 26%; --y: 75%; --w: 58%; --h: 13%;",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#102236" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:site_name" content="Neo Mall" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Neo Mall concept rendering with the Neo Mall logo" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-S1JK3M5H19"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-S1JK3M5H19');
    </script>
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Neo Mall",
        "url": "https://neomall.resist.design/",
        "description": "Neo Mall reframes the mall as a free-to-enter daily resort town square built around food, play, water, entertainment, work, comfort, and community.",
        "image": "https://neomall.resist.design/og-image.png",
        "about": {
          "@type": "Thing",
          "name": "Mixed-use destination concept"
        }
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header" aria-label="Primary navigation">
      <a class="brand-mark" href="#top" aria-label="Neo Mall home">
        <img src="/assets/brand/neo-mall-logo.svg" alt="Neo Mall" />
      </a>
      <nav>
        {navItems.map(([href, label]) => <a href={href}>{label}</a>)}
      </nav>
    </header>

    <main id="top">
      <section class="scene hero-scene" style="--scene: url('/assets/scenes/hero.webp')">
        <div class="scene-copy hero-copy">
          <p class="eyebrow">Concept Vision</p>
          <h1><span>Neo</span><span>Mall</span></h1>
          <p>
            A free-to-enter resort-style town square built around food, play,
            water, entertainment, work, and community.
          </p>
          <a class="button" href="#vision" data-track="hero_cta" data-track-label="Explore the idea">Explore the idea</a>
        </div>
      </section>

      <section id="vision" class="thesis">
        <div>
          <p class="eyebrow">The Big Move</p>
          <h2>Do not save retail. Save the destination.</h2>
        </div>
        <p>
          Neo Mall reframes the mall as a daily-use resort: free commons,
          optional paid experiences, and enough variety that people can arrive
          without a plan and still stay for hours.
        </p>
      </section>

      <section class="scene" style="--scene: url('/assets/scenes/aerial.webp')">
        <div class="scene-copy align-right">
          <p class="eyebrow">Master Vision</p>
          <h2>A C-shaped destination campus, open to water and wrapped by covered promenades.</h2>
          <p>
            The mall is not a closed box. It is a roofed arcade around a
            designed courtyard, with the water side open and entertainment
            concentrated on the active edge.
          </p>
        </div>
      </section>

      <section class="program-strip" aria-label="Program stack">
        <div class="section-title">
          <p class="eyebrow">Program Stack</p>
          <h2>A compact set of anchors that reinforce each other.</h2>
        </div>
        <div class="stack-grid">
          {stack.map(([title, text]) => (
            <article>
              <h3>{title}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="moments" class="moments">
        {moments.map((moment, index) => (
          <article class={`scene moment-scene ${index % 2 ? "copy-right" : ""}`} style={`--scene: url('${moment.image}')`}>
            <div class="scene-copy">
              <p class="eyebrow">{String(index + 1).padStart(2, "0")} / Destination Moment</p>
              <h2>{moment.title}</h2>
              <p>{moment.text}</p>
            </div>
          </article>
        ))}
      </section>

      <section id="map" class="map-section">
        <div class="section-title">
          <p class="eyebrow">Interactive Diagram</p>
          <h2>Tap a zone to see how the pieces work together.</h2>
        </div>
        <div class="map-shell" data-map>
          <div class="map-stage" aria-label="Interactive Neo Mall concept diagram">
            {zones.map((zone, index) => (
              <button
                class={`map-zone ${index === 0 ? "is-active" : ""}`}
                style={zone.style}
                type="button"
                data-zone={zone.id}
                aria-pressed={index === 0 ? "true" : "false"}
              >
                <span>{zone.label}</span>
              </button>
            ))}
          </div>
          <aside class="map-info" aria-live="polite">
            <p class="eyebrow" data-zone-kicker>Water Park Edge</p>
            <h3 data-zone-title>Water Park Edge</h3>
            <p data-zone-text>
              The left edge stays open to water so the attraction feels connected
              to the public space instead of bolted on.
            </p>
          </aside>
        </div>
      </section>

      <section id="rhythm" class="rhythm-section">
        <div class="scene rhythm-visual" style="--scene: url('/assets/scenes/aerial.webp')">
          <div class="scene-copy">
            <p class="eyebrow">A Day Without A Plan</p>
            <h2>Enough variety to arrive casually and stay naturally.</h2>
          </div>
        </div>
        <ol class="day-list" aria-label="Example day plan">
          {planStops.map(([time, activity]) => (
            <li>
              <time>{time}</time>
              <span>{activity}</span>
            </li>
          ))}
        </ol>
      </section>

      <section class="principles">
        <div class="section-title">
          <p class="eyebrow">Operating Principles</p>
          <h2>The boring stuff is what lets the fun stuff work all day.</h2>
        </div>
        <div class="principle-grid">
          <article>
            <h3>Free Commons</h3>
            <p>Entry, lawns, walkways, seating, shade, bathrooms, and WiFi remain free to use.</p>
          </article>
          <article>
            <h3>Paid Destinations</h3>
            <p>Theater, bowling, arcade, water attractions, food, shops, services, and events create revenue.</p>
          </article>
          <article>
            <h3>Weather Resilience</h3>
            <p>Covered promenades and indoor-outdoor flexibility protect the day from heat, rain, and seasonal shifts.</p>
          </article>
          <article>
            <h3>All-Day Comfort</h3>
            <p>Bathrooms, family restrooms, lockers, charging points, first aid, security, and shade are core infrastructure.</p>
          </article>
        </div>
      </section>

      <section class="scene finale" style="--scene: url('/assets/scenes/night.webp')">
        <div class="scene-copy">
          <p class="eyebrow">The Mall As A Daily Resort</p>
          <h2>A place you can enter for free, stay without pressure, and spend only when you choose.</h2>
          <p>
            Neo Mall is not retail with decorations. It is a community destination
            with food, water, play, work, movement, comfort, and entertainment
            arranged so each part makes the others stronger.
          </p>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>Neo Mall</p>
      <a href="#top" data-track="footer_back_to_top" data-track-label="Back to top">Back to top</a>
    </footer>

    <script is:inline>
      const zoneContent = {
        water: {
          kicker: "Water Park Edge",
          title: "Water Park Edge",
          text: "The left edge stays open to water so the attraction feels connected to the public space instead of bolted on.",
        },
        "food-north": {
          kicker: "Food And Cafe Spine",
          title: "North Food Spine",
          text: "Food and cafe frontage frame both sides of the commons, turning ordinary meals into the main social engine.",
        },
        roof: {
          kicker: "Covered Promenade",
          title: "Weather-Protected Seating",
          text: "A roofed promenade makes the place usable in heat, rain, and cooler months while keeping the courtyard visible.",
        },
        pool: {
          kicker: "Wave Pool Feature",
          title: "Visible Water Anchor",
          text: "The pool is the visual anchor: social, visible, and memorable without consuming the entire identity.",
        },
        commons: {
          kicker: "Free Commons",
          title: "Outdoor Seating And Play",
          text: "Open lawn and seating form the free daily commons where people can arrive without buying a ticket.",
        },
        entertainment: {
          kicker: "Entertainment Edge",
          title: "Arcade, Bowling, Theater",
          text: "Arcade, bowling, theater, and service uses concentrate on the active side so nights have a clear destination.",
        },
        "food-south": {
          kicker: "South Food Spine",
          title: "Second Food Edge",
          text: "A second food edge creates loops, choices, and reasons to move through the whole site.",
        },
      };

      const map = document.querySelector("[data-map]");
      if (map) {
        const buttons = Array.from(map.querySelectorAll("[data-zone]"));
        const kicker = map.querySelector("[data-zone-kicker]");
        const title = map.querySelector("[data-zone-title]");
        const text = map.querySelector("[data-zone-text]");

        if (kicker && title && text) buttons.forEach((button) => {
          button.addEventListener("click", () => {
            if (!(button instanceof HTMLElement)) return;
            const zoneId = button.dataset.zone;
            if (!zoneId || !(zoneId in zoneContent)) return;
            const content = zoneContent[zoneId];
            if (!content) return;
            buttons.forEach((item) => {
              item.classList.toggle("is-active", item === button);
              item.setAttribute("aria-pressed", item === button ? "true" : "false");
            });
            kicker.textContent = content.kicker;
            title.textContent = content.title;
            text.textContent = content.text;
            trackEvent("map_zone_select", { zone_id: zoneId, zone_title: content.title });
          });
        });
      }

      function trackEvent(name, params = {}) {
        if (typeof window.gtag === "function") {
          window.gtag("event", name, params);
        }
      }

      document.querySelectorAll("a[href^='#']").forEach((link) => {
        link.addEventListener("click", () => {
          const label = link.getAttribute("data-track-label") || link.textContent.trim();
          const destination = link.getAttribute("href");
          trackEvent(link.dataset.track || "nav_click", { link_text: label, destination });
        });
      });

      document.querySelectorAll(".day-list li").forEach((item) => {
        item.addEventListener("click", () => {
          const time = item.querySelector("time")?.textContent?.trim();
          const activity = item.querySelector("span")?.textContent?.trim();
          trackEvent("day_plan_select", { time, activity });
        });
      });

      const sections = ["vision", "moments", "map", "rhythm"].map((id) => document.getElementById(id)).filter(Boolean);
      const seenSections = new Set();
      if ("IntersectionObserver" in window) {
        const sectionObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting || seenSections.has(entry.target.id)) return;
            seenSections.add(entry.target.id);
            trackEvent("section_view", { section_id: entry.target.id });
          });
        }, { threshold: 0.45 });
        sections.forEach((section) => sectionObserver.observe(section));
      }

      const scrollMarks = [25, 50, 75, 100];
      const seenScrollMarks = new Set();
      window.addEventListener("scroll", () => {
        const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
        if (maxScroll <= 0) return;
        const depth = Math.min(100, Math.round((window.scrollY / maxScroll) * 100));
        scrollMarks.forEach((mark) => {
          if (depth >= mark && !seenScrollMarks.has(mark)) {
            seenScrollMarks.add(mark);
            trackEvent("scroll_depth", { percent_scrolled: mark });
          }
        });
      }, { passive: true });
    </script>
  </body>
</html>
